{
  "name": "vue-feature-toggles",
  "version": "0.1.6",
  "description": "Lightweight, backend-agnostic feature flags plugin for Vue 3",
  "type": "module",
  "main": "./dist/vue-feature-toggles.cjs",
  "module": "./dist/vue-feature-toggles.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-feature-toggles.js",
      "require": "./dist/vue-feature-toggles.cjs"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./storybook": {
      "import": "./dist/storybook.js",
      "require": "./dist/storybook.cjs"
    },
    "./nuxt": "./nuxt/module.ts"
  },
  "bin": {
    "vue-feature-toggles": "./bin/cli.js"
  },
  "files": [
    "dist",
    "nuxt",
    "bin"
  ],
  "scripts": {
    "dev": "vite serve demo --config demo/vite.config.ts",
    "build": "vite build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "@vue/devtools-api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^3.17.3",
    "@nuxt/schema": "^3.17.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/devtools-api": "^8.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  }
}
